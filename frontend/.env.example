# Copy this file to .env.local (gitignored) and fill in real values.
#
# Both vars are optional: without them, the leaderboard feature simply
# doesn't appear (isLeaderboardAvailable() returns false) -- the game
# itself needs no backend at all.
#
# For local development against the Supabase CLI's local stack
# (`supabase start`), use the printed "API URL" and "anon key" values.
# For production, use your hosted project's values from
# Project Settings -> API in the Supabase dashboard.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
